# Chave da YouTube Data API v3 (Google Cloud Console).
# Restrinja por HTTP referrer ao domínio onde o app for hospedado.
VITE_YOUTUBE_API_KEY=

# ID de cliente OAuth 2.0 (tipo "Aplicativo da Web"), mesmo projeto do Google Cloud.
# Origem JavaScript autorizada precisa ser o domínio de producao.
VITE_GOOGLE_CLIENT_ID=

# Chave da API da Anthropic (console.anthropic.com) — usada só pela Vercel
# Function em api/search-expand.ts (busca inteligente, item 4). NUNCA prefixar
# com VITE_: qualquer variável VITE_ é embutida no bundle do navegador, o que
# exporia a chave publicamente. Configurar como variável de ambiente do
# servidor (Vercel: Project Settings > Environment Variables).
ANTHROPIC_API_KEY=
