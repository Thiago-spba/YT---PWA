# Chave da YouTube Data API v3 (Google Cloud Console) â€” usada sĂ³ pela Vercel
# Function em api/youtube.ts. NUNCA prefixar com VITE_: isso a embutiria no
# bundle do navegador, expondo-a publicamente. Configurar como variĂ¡vel de
# ambiente do servidor (Vercel: Project Settings > Environment Variables).
YOUTUBE_API_KEY=

# ID de cliente OAuth 2.0 (tipo "Aplicativo da Web"), mesmo projeto do Google Cloud.
# Origem JavaScript autorizada precisa ser o domĂ­nio de producao.
VITE_GOOGLE_CLIENT_ID=

# Chave da API da Anthropic (console.anthropic.com) â€” usada sĂ³ pela Vercel
# Function em api/search-expand.ts (busca inteligente, item 4). NUNCA prefixar
# com VITE_: qualquer variĂ¡vel VITE_ Ă© embutida no bundle do navegador, o que
# exporia a chave publicamente. Configurar como variĂ¡vel de ambiente do
# servidor (Vercel: Project Settings > Environment Variables).
ANTHROPIC_API_KEY=

# Firebase Configuration (para sincronizaçăo de progresso de vídeo no Firestore)
# Configure no Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
